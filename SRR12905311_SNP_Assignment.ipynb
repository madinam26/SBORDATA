# Study metadata (SRA + GEO)
import json
from urllib.request import urlopen

RUN = "SRR12905311"
GSM = "GSM4862160"
print("Accession:", RUN, "GEO:", GSM)

try:
    runinfo_url = f"https://trace.ncbi.nlm.nih.gov/Traces/sra/sra.cgi?save=efetch&db=sra&rettype=runinfo&term={RUN}"
    runinfo = urlopen(runinfo_url, timeout=30).read().decode()
    print(runinfo.splitlines()[0])
    print("...", runinfo.splitlines()[1][:200])
except Exception as e:
    print("RunInfo fetch failed:", e)

try:
    geo_url = f"https://www.ncbi.nlm.nih.gov/geo/query/acc.cgi?acc={GSM}&targ=self&form=text&view=full"
    geo_text = urlopen(geo_url, timeout=30).read().decode(errors='ignore')
    print(geo_text[:500])
except Exception as e:
    print("GEO fetch failed:", e)# SNP discovery for SRR12905311 (GEO: GSM4862160)

This notebook performs:
- Download of SRA reads (SRR12905311)
- QC (FastQC, MultiQC) and trimming (fastp)
- Reference genome/GFF fetch from NCBI (auto-guess organism via metadata)
- Alignment (BWA), SNP calling (bcftools)
- Mapping SNPs to genes and selecting 3–4 candidates
- Brief interpretation (non-human dataset)

Run top-to-bottom in Google Colab.
