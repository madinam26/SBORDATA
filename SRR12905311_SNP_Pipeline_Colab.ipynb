import os, glob, subprocess, pandas as pd
from urllib.request import urlopen

RUN = "SRR12905311"
organism = None
try:
    runinfo_url = f"https://trace.ncbi.nlm.nih.gov/Traces/sra/sra.cgi?save=efetch&db=sra&rettype=runinfo&term={RUN}"
    df = pd.read_csv(runinfo_url)
    if "Organism" in df.columns and len(df):
        organism = df["Organism"].iloc[0]
except Exception:
    pass
organism = organism or "Neisseria gonorrhoeae"
print("Using organism:", organism)

os.makedirs("ref", exist_ok=True)
levels = ["complete", "chromosome", "scaffold"]
for level in levels:
    code = subprocess.call([
        "ncbi-genome-download", "bacteria", "-s", "refseq", "-F", "fasta,gff", "-g", organism,
        "--assembly-level", level, "--refseq-category", "reference", "--output-folder", "ref"
    ])
    if code == 0:
        break

fasta = None; gff = None
for path in glob.glob("ref/**/GCF_*/**/*.fna.gz", recursive=True): fasta = path
for path in glob.glob("ref/**/GCF_*/**/*.gff.gz", recursive=True): gff = path

if not fasta or not gff:
    subprocess.call(["ncbi-genome-download", "bacteria", "-s", "genbank", "-F", "fasta,gff", "-g", organism, "--output-folder", "ref"])
    for path in glob.glob("ref/**/GCF_*/**/*.fna.gz", recursive=True): fasta = path
    for path in glob.glob("ref/**/GCF_*/**/*.gff.gz", recursive=True): gff = path
assert fasta and gff, "Reference not found"

subprocess.check_call(["gunzip", "-f", fasta]); fasta = fasta[:-3]
subprocess.check_call(["gunzip", "-f", gff]); gff = gff[:-3]
print("Reference:", fasta)
print("GFF:", gff)
subprocess.check_call(["bwa", "index", fasta])
subprocess.check_call(["samtools", "faidx", fasta])%%bash
