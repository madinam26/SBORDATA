# Map variants to genes and generate NCBI links
import os, pandas as pd
from pathlib import Path

RUN = "SRR12905311"
vcf_gz = f"{RUN}.flt.vcf.gz"
ref_gff = list(Path("ref").glob("**/GCF_*/**/*.gff"))[0]

# Parse VCF
records = []
with os.popen(f"bcftools view -H {vcf_gz}") as fh:
    for ln in fh:
        chrom, pos, vid, ref, alt, qual, flt, info, *rest = ln.rstrip().split("\t")
        records.append({"chrom":chrom, "pos":int(pos), "ref":ref, "alt":alt, "qual":float(qual) if qual!='.' else 0.0})
vcf_df = pd.DataFrame(records)

# Parse GFF (CDS/gene)
genes = []
with open(ref_gff) as fh:
    for ln in fh:
        if ln.startswith('#'): continue
        f = ln.rstrip().split('\t')
        if len(f) < 9: continue
        if f[2] not in ("gene","CDS"): continue
        attrs = {}
        for kv in f[8].split(';'):
            if '=' in kv:
                k,v = kv.split('=',1)
                attrs[k]=v
        genes.append({"chrom":f[0], "start":int(f[3]), "end":int(f[4]), "feature":f[2],
                      "gene":attrs.get("gene") or attrs.get("Name") or attrs.get("locus_tag"),
                      "product":attrs.get("product") or attrs.get("Note")})
ann = pd.DataFrame(genes)

hits = []
for _,v in vcf_df.iterrows():
    ovl = ann[(ann.chrom==v.chrom) & (ann.start<=v.pos) & (ann.end>=v.pos) & (ann.feature=='CDS')]
    if ovl.empty:
        ovl = ann[(ann.chrom==v.chrom) & (ann.start<=v.pos) & (ann.end>=v.pos) & (ann.feature=='gene')]
    if ovl.empty:
        hits.append({**v.to_dict(), "gene":None, "product":None})
    else:
        row = ovl.iloc[0]
        hits.append({**v.to_dict(), "gene":row.gene, "product":row.product})

hits_df = pd.DataFrame(hits).sort_values('qual', ascending=False)
selected = hits_df[hits_df.gene.notna()].head(4)
selected['ncbi_gene_search'] = selected['gene'].apply(lambda g: f"https://www.ncbi.nlm.nih.gov/gene/?term={g}")
selected.to_csv('selected_snps.tsv', sep='\t', index=False)
