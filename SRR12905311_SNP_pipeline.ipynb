import os, re, json, subprocess, glob, shutil

RUN = "SRR12905311"

# Try to infer organism name from RunInfo CSV saved earlier (if user printed it)
# Fallback to Neisseria gonorrhoeae which is common for similar runs
inferred_organism = None
try:
    import pandas as pd
    import io
    from urllib.request import urlopen
    runinfo_url = f"https://trace.ncbi.nlm.nih.gov/Traces/sra/sra.cgi?save=efetch&db=sra&rettype=runinfo&term={RUN}"
    csv_text = urlopen(runinfo_url, timeout=30).read().decode()
    df = pd.read_csv(io.StringIO(csv_text))
    if "Organism" in df.columns and len(df["Organism"])>0:
        inferred_organism = str(df["Organism"].iloc[0])
except Exception as e:
    pass

organism = inferred_organism or "Neisseria gonorrhoeae"
print("Using organism:", organism)

# Download RefSeq assembly (complete/chromosome) with ncbi-genome-download
os.makedirs("ref", exist_ok=True)
levels = ["complete", "chromosome", "scaffold"]
for level in levels:
    code = subprocess.call([
        "ncbi-genome-download", "bacteria", "-s", "refseq", "-F", "fasta,gff", "-g", organism,
        "--assembly-level", level, "--refseq-category", "reference", "--output-folder", "ref"
    ])
    if code == 0:
        break

# Locate FASTA and GFF
fasta = None
gff = None
for path in glob.glob("ref/**/GCF_*/**/*.fna.gz", recursive=True):
    fasta = path
for path in glob.glob("ref/**/GCF_*/**/*.gff.gz", recursive=True):
    gff = path

if not fasta or not gff:
    # Fallback: try genbank or any assembly
    subprocess.call(["ncbi-genome-download", "bacteria", "-s", "genbank", "-F", "fasta,gff", "-g", organism, "--output-folder", "ref"])
    for path in glob.glob("ref/**/GCF_*/**/*.fna.gz", recursive=True):
        fasta = path
    for path in glob.glob("ref/**/GCF_*/**/*.gff.gz", recursive=True):
        gff = path

assert fasta and gff, "Reference FASTA/GFF not found. Please adjust organism."
print("Reference FASTA:", fasta)
print("Reference GFF:", gff)

# Decompress and index
subprocess.check_call(["gunzip", "-f", fasta])
subprocess.check_call(["gunzip", "-f", gff])
fasta = fasta[:-3]
gff = gff[:-3]

subprocess.check_call(["bwa", "index", fasta])
subprocess.check_call(["samtools", "faidx", fasta])
