# Intersect variants with GFF to map to genes and pick 3-4
import os, gzip, re, json, pandas as pd
from pathlib import Path

RUN = "SRR12905311"
vcf_gz = f"{RUN}.flt.vcf.gz"
ref_gff = list(Path("ref").glob("**/GCF_*/**/*.gff"))[0]

# Load VCF into DataFrame (simple parser)
variants = []
with os.popen(f"bcftools view -H {vcf_gz}") as fh:
    for line in fh:
        chrom, pos, vid, ref, alt, qual, flt, info, *rest = line.strip().split("\t")
        pos = int(pos)
        qual = float(qual) if qual != '.' else 0.0
        variants.append({"chrom":chrom, "pos":pos, "ref":ref, "alt":alt, "qual":qual, "info":info})

# Load GFF genes
genes = []
with open(ref_gff, "r") as fh:
    for ln in fh:
        if not ln or ln.startswith("#"): continue
        fields = ln.strip().split("\t")
        if len(fields) < 9: continue
        chrom, source, feature, start, end, score, strand, phase, attrs = fields
        if feature not in ("gene", "CDS"): continue
        attr = {}
        for kv in attrs.split(";"):
            if "=" in kv:
                k,v = kv.split("=",1)
                attr[k]=v
        gene = attr.get("gene") or attr.get("Name") or attr.get("locus_tag") or attr.get("GeneID")
        product = attr.get("product") or attr.get("Note")
        genes.append({"chrom":chrom, "start":int(start), "end":int(end), "strand":strand, "feature":feature, "gene":gene, "product":product, "attrs":attr})

genes_df = pd.DataFrame(genes)

# Map variants to genes
hits = []
for var in variants:
    overlapped = genes_df[(genes_df.chrom==var["chrom"]) & (genes_df.start<=var["pos"]) & (genes_df.end>=var["pos"]) & (genes_df.feature=="CDS")]
    if len(overlapped)==0:
        overlapped = genes_df[(genes_df.chrom==var["chrom"]) & (genes_df.start<=var["pos"]) & (genes_df.end>=var["pos"]) & (genes_df.feature=="gene")]
    gene_name = overlapped["gene"].iloc[0] if len(overlapped)>0 else None
    product = overlapped["product"].iloc[0] if len(overlapped)>0 else None
    hits.append({**var, "gene": gene_name, "product": product})

hits_df = pd.DataFrame(hits)
# Prefer coding hits and high quality
coding = hits_df[hits_df.gene.notna()].sort_values(["qual"], ascending=False)
selected = coding.head(4)
selected.to_csv("selected_snps.tsv", sep="\t", index=False)
